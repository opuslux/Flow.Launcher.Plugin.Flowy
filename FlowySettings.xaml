<UserControl x:Class="Flow.Launcher.Plugin.Flowy.FlowySettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">

    <UserControl.Resources>
        <Style x:Key="PlaceholderTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#55888888"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="5,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                            </Border>
                            <TextBlock x:Name="Watermark" Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="#888888" Margin="5,0,10,0"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"
                                       Visibility="Collapsed" IsHitTestVisible="False" FontSize="12" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#AA0078D7"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="DirectoryList" Grid.Row="0" Background="Transparent" BorderThickness="0" 
                 MaxHeight="300"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="False"
                 HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                 Margin="0,0,0,10"
                 TextBoxBase.TextChanged="UIField_Changed"
                 ToggleButton.Checked="UIField_Changed"
                 ToggleButton.Unchecked="UIField_Changed">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#33888888" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,15,8" Background="#08888888">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="35"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Index}" Grid.Column="0" VerticalAlignment="Center" Foreground="Gray" FontWeight="Bold" Margin="0,0,5,0"/>

                                <TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="0,0,10,0" Style="{StaticResource PlaceholderTextBoxStyle}" Tag="C:\Folder\Path"/>

                                <TextBox Text="{Binding DepthDisplay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="2" Margin="0,0,10,0" Style="{StaticResource PlaceholderTextBoxStyle}" Tag="Depth"/>

                                <TextBox Text="{Binding FileTypesDisplay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="3" Margin="0,0,10,0" Style="{StaticResource PlaceholderTextBoxStyle}" Tag="*.lnk; *.pdf"/>

                                <CheckBox IsChecked="{Binding IncludeDirectories, UpdateSourceTrigger=PropertyChanged}" Content="Folders" Grid.Column="4" VerticalAlignment="Center"/>

                                <Button Content="✕" Grid.Column="5" Click="RemoveRow_Click" ToolTip="Remove folder" 
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" 
                                        Foreground="#CC5555" FontSize="16" FontWeight="Bold" 
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Padding="5,0"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource PlaceholderTextBoxStyle}" Tag="Comment / Note"/>

                                <TextBlock Grid.Column="1" VerticalAlignment="Bottom" Foreground="#999999" FontSize="11" Margin="0,0,0,3">
                                    <Run Text="{Binding FileCount, Mode=OneWay}"/>
                                    <Run Text=" Files | "/>
                                    <Run Text="{Binding FolderCount, Mode=OneWay}"/>
                                    <Run Text=" Folders"/>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="1" Margin="0,10,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Auto-scan every" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="IntervalTextBox" Width="40" Text="{Binding RescanIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" PreviewTextInput="NumberValidationTextBox" TextChanged="IntervalTextBox_TextChanged" Padding="0,2"/>
                <TextBlock Text="minutes" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>

            <ProgressBar x:Name="ScanProgressBar" Grid.Column="1" Height="4" Margin="20,0,20,0" IsIndeterminate="True" Visibility="Collapsed" VerticalAlignment="Center" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="➕ Add Folder" Click="AddFolder_Click" Padding="15,7" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="Rescan Catalog" Click="Rescan_Click" Padding="15,7" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="📥 Import Settings" Click="Import_Click" Padding="15,7" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="📤 Export Settings" Click="Export_Click" Padding="15,7" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>