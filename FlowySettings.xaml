<UserControl x:Class="Flow.Launcher.Plugin.Flowy.FlowySettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="DirectoryGrid" 
                  Grid.Row="0" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="Transparent"           
                  RowBackground="Transparent"        
                  SelectionMode="Single"
                  MaxHeight="250" 
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  CellEditEnding="DirectoryGrid_CellEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Folder Path" Binding="{Binding Path}" Width="*" />
                <DataGridTextColumn Header="Depth" Binding="{Binding Depth}" Width="50" />
                <DataGridTextColumn Header="File Types" Binding="{Binding FileTypesDisplay}" Width="150" />
                <DataGridCheckBoxColumn Header="Folders?" Binding="{Binding IncludeDirectories}" Width="65" />
                <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" IsReadOnly="True" Width="60" />
                <DataGridTextColumn Header="Folders" Binding="{Binding FolderCount}" IsReadOnly="True" Width="60" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Auto-scan every" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="IntervalTextBox" Width="40" Text="{Binding RescanIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" PreviewTextInput="NumberValidationTextBox" TextChanged="IntervalTextBox_TextChanged"/>
                <TextBlock Text="minutes" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>

            <ProgressBar x:Name="ScanProgressBar" Grid.Column="1" Height="6" Margin="20,0,20,0" IsIndeterminate="True" Visibility="Collapsed" VerticalAlignment="Center" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Rescan Catalog" Click="Rescan_Click" Padding="15,7" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="➕ Add Folder" Click="AddFolder_Click" Padding="15,7" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="➖ Remove Folder" Click="RemoveFolder_Click" Padding="15,7" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>