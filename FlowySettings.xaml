<UserControl x:Class="Flow.Launcher.Plugin.Flowy.FlowySettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             HorizontalAlignment="Stretch"
             HorizontalContentAlignment="Stretch">

    <UserControl.Resources>
        <Style x:Key="PlaceholderTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Padding"
                    Value="5,4"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource Color05B}"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource Color03B}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0"/>
                            </Border>
                            <TextBlock x:Name="Watermark"
                                       Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="{DynamicResource Color18B}"
                                       Margin="7,0,10,0"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False"
                                       FontSize="12"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text"
                                               Value=""/>
                                    <Condition Property="IsFocused"
                                               Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Watermark"
                                        Property="Visibility"
                                        Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomExpanderStyle"
               TargetType="Expander">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Stretch"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource Color03B}"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource Color05B}"/>
            <Setter Property="BorderThickness"
                    Value="0 0 0 1"/>
            <Setter Property="Padding"
                    Value="24 18 24 14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              DockPanel.Dock="Top"
                                              Padding="{TemplateBinding Padding}"
                                              Foreground="{TemplateBinding Foreground}"
                                              IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Style="{DynamicResource ExpanderHeaderRightArrowStyle}"
                                              Content="{TemplateBinding Header}"/>
                                <ContentPresenter x:Name="ExpandSite"
                                                  Visibility="Collapsed"
                                                  DockPanel.Dock="Bottom"
                                                  Margin="{TemplateBinding Padding}"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded"
                                     Value="true">
                                <Setter TargetName="ExpandSite"
                                        Property="Visibility"
                                        Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="-2 0 -2 0">

        <Expander Header="General Setting"
                  IsExpanded="False"
                  Style="{StaticResource CustomExpanderStyle}">
            <Grid Margin="32 -10 0 10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Maximum results to return:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Color05B}"
                           Margin="0,5"/>
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Width="80"
                         HorizontalAlignment="Left"
                         Text="{Binding MaxResults, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource PlaceholderTextBoxStyle}"
                         Tag="1000"
                         PreviewTextInput="NumberValidationTextBox"
                         TextChanged="UIField_Changed"/>

                <TextBlock Grid.Row="1"
                           Text="Autoscan interval (min):"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Color05B}"
                           Margin="0,5"/>
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Width="80"
                         HorizontalAlignment="Left"
                         Text="{Binding RescanIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource PlaceholderTextBoxStyle}"
                         Tag="30"
                         PreviewTextInput="NumberValidationTextBox"
                         TextChanged="IntervalTextBox_TextChanged"/>

                <CheckBox Grid.Row="2"
                          Grid.ColumnSpan="2"
                          IsChecked="{Binding ShowRuleNumber, UpdateSourceTrigger=PropertyChanged}"
                          Content="Show Catalogue Rule Number in results (e.g. #7 | ...)"
                          Foreground="{DynamicResource Color05B}"
                          Margin="0,15,0,15"
                          Checked="UIField_Changed"
                          Unchecked="UIField_Changed"/>

                <StackPanel Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Margin="0,0,0,10">
                    <Button Content="📥 Import Settings"
                            Click="Import_Click"
                            Padding="15,5"
                            Margin="0,0,10,0"
                            Cursor="Hand"/>
                    <Button Content="📤 Export Settings"
                            Click="Export_Click"
                            Padding="15,5"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Expander>

        <Expander Header="Catalogue Rules"
                  IsExpanded="False"
                  Style="{StaticResource CustomExpanderStyle}">
            <Grid Margin="32 -10 0 10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox x:Name="DirectoryList"
                         Grid.Row="0"
                         Background="Transparent"
                         BorderThickness="0"
                         MaxHeight="500"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch"/>
                            <Setter Property="Padding"
                                    Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource Color03B}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10"
                                    Margin="0,0,15,8"
                                    Background="Transparent">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="25"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="45"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Index, StringFormat='#{0}'}"
                                                   Foreground="{DynamicResource Color18B}"
                                                   FontWeight="Bold"
                                                   ToolTip="Index of this rule"/>
                                    </StackPanel>

                                    <TextBox Grid.Row="0"
                                            Grid.Column="1"
                                            Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="0,0,8,10"
                                            Style="{StaticResource PlaceholderTextBoxStyle}"
                                            Tag="Path"
                                             ToolTip="Full directory path (e.g. C:\Tools or %UserProfile%\Desktop)"/>

                                    <TextBox Grid.Row="0"
                                            Grid.Column="2"
                                            Text="{Binding DepthDisplay, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="0,0,8,10"
                                            Style="{StaticResource PlaceholderTextBoxStyle}"
                                            Tag="D"
                                             ToolTip="Search depth: 0 = this folder only, 1 = one sub-level, etc."/>

                                    <TextBox Grid.Row="0"
                                            Grid.Column="3"
                                            Text="{Binding FileTypesDisplay, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="0,0,8,10"
                                            Style="{StaticResource PlaceholderTextBoxStyle}"
                                            Tag="*.*"
                                             ToolTip="Filter file extensions (e.g. *.exe; *.lnk). Leave empty to scan NO files (Folders only)."/>

                                    <CheckBox Grid.Row="0"
                                            Grid.Column="4"
                                            IsChecked="{Binding IncludeDirectories, UpdateSourceTrigger=PropertyChanged}"
                                            Content="Folders"
                                            Foreground="{DynamicResource Color05B}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,0,10"
                                              ToolTip="Should folders themselves be shown as search results?"/>

                                    <Button Grid.Row="0"
                                            Grid.Column="5"
                                            Content="✕"
                                            Margin="0,0,0,10"
                                            HorizontalAlignment="Right"
                                            Click="RemoveRow_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#FF5555"
                                            FontWeight="Bold"
                                            ToolTip="Delete this rule permanently"/>

                                    <TextBox Grid.Row="1"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="4"
                                            Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource PlaceholderTextBoxStyle}"
                                            Tag="Comment"
                                             ToolTip="Personal comment or note for this entry"/>

                                    <TextBlock Grid.Row="1"
                                            Grid.Column="5"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Right"
                                            Foreground="{DynamicResource Color18B}"
                                            FontSize="10"
                                               ToolTip="Number of currently indexed files (F) and directories (D)">
                    <Run Text="{Binding FileCount, Mode=OneWay}"/> files | <Run Text="{Binding FolderCount, Mode=OneWay}"/> folders
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,15,15,10">
                    <Button Content="➕ Add Folder"
                            Click="AddFolder_Click"
                            Padding="15,5"
                            Margin="0,0,10,0"/>
                    <Button Content="Rescan Catalog"
                            Click="Rescan_Click"
                            Padding="15,5"/>
                </StackPanel>
                <ProgressBar x:Name="ScanProgressBar"
                             Grid.Row="2"
                             Height="3"
                             Margin="0,5,15,10"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
            </Grid>
        </Expander>
    </StackPanel>
</UserControl>